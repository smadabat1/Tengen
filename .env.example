# -----------------------------------------------------------------------
# Tengen — Environment Variables
# Copy this file to .env and fill in your values before running.
# -----------------------------------------------------------------------

# JWT signing secret — CHANGE THIS before deploying
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# Token expiry in minutes (default 60)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Paths inside the container (do not change unless you update docker-compose.yml)
DATA_DIR=/app/data
LOG_DIR=/app/logs

# Argon2id parameters — increase for stronger security at the cost of login time
ARGON2_TIME_COST=3
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=2

# Set to true to enable DEBUG logging and console output
DEBUG=false
